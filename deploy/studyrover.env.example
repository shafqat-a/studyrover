# StudyRover backend runtime config (consumed by systemd EnvironmentFile).
# Copy to studyrover.env and fill in secrets. deploy.sh generates studyrover.env
# automatically (random SESSION_SECRET + provisioned DB password) if absent.

PORT=8080

# Postgres on the existing local instance (deploy.sh provisions role + db).
DATABASE_URL=postgres://studyrover:CHANGE_ME@127.0.0.1:5432/studyrover?sslmode=disable

# Session cookie signing secret (use: openssl rand -hex 32).
SESSION_SECRET=CHANGE_ME

# WebAuthn / FIDO2 relying party (parent auth). RP_ID is the registrable domain;
# the origin is the https URL the user visits. The /studyrover subpath is NOT
# part of RP_ID or origin (WebAuthn is path-agnostic).
RP_ID=home.cloudlabs.live
RP_ORIGIN=https://home.cloudlabs.live
