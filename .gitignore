# ---- Go (backend) ----
/backend/bin/
/backend/server
/backend/cmd/server/server
*.test
*.out
coverage.out
coverage.html

# Embedded SPA build output (generated into the backend at build time)
/backend/internal/http/dist/
/backend/internal/http/static/dist/

# ---- Node / Frontend (build-time only) ----
node_modules/
/frontend/node_modules/
/frontend/dist/
